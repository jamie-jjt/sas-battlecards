---
interface Props {
  title: string;
  icon?: string;
  defaultOpen?: boolean;
}

const { title, icon, defaultOpen = false } = Astro.props;
---

<section class="border border-border-default rounded-lg overflow-hidden">
  <details open={defaultOpen} class="group">
    <summary class="flex items-center justify-between gap-3 px-4 py-3 bg-bg-surface hover:bg-bg-elevated cursor-pointer select-none transition-colors duration-150 list-none [&::-webkit-details-marker]:hidden">
      <div class="flex items-center gap-2">
        {icon && <span class="text-base" aria-hidden="true">{icon}</span>}
        <h3 class="text-base font-semibold text-text-primary">{title}</h3>
      </div>
      <svg
        class="w-4 h-4 text-text-muted transition-transform duration-200 group-open:rotate-180"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </summary>
    <div class="px-4 py-4 border-t border-border-muted">
      <slot />
    </div>
  </details>
</section>
