---
import type { ThreatLevel } from '@lib/types';

interface Props {
  level: ThreatLevel;
}

const { level } = Astro.props;

const config: Record<ThreatLevel, { dot: string; text: string; label: string }> = {
  high: { dot: 'bg-threat-high', text: 'text-threat-high', label: 'High' },
  medium: { dot: 'bg-threat-medium', text: 'text-threat-medium', label: 'Medium' },
  low: { dot: 'bg-threat-low', text: 'text-threat-low', label: 'Low' },
};

const { dot, text, label } = config[level];
---

<span class:list={["inline-flex items-center gap-1.5 text-xs font-medium", text]}>
  <span class:list={["w-2 h-2 rounded-full", dot]} aria-hidden="true"></span>
  {label}
</span>
