---
interface ChipOption {
  value: string;
  label: string;
  color?: string;
}

interface Props {
  id: string;
  label: string;
  options: ChipOption[];
  filterKey: string;
}

const { id, label, options, filterKey } = Astro.props;
---

<div class="filter-chips" data-filter-key={filterKey} id={id}>
  <span class="text-xs font-medium text-text-muted uppercase tracking-wider mr-2 shrink-0">
    {label}:
  </span>
  <div class="flex items-center gap-1.5 overflow-x-auto pb-1 scrollbar-hide">
    <!-- All chip (active by default) -->
    <button
      type="button"
      class="chip chip--active"
      data-value="all"
      aria-pressed="true"
    >
      All
    </button>

    {options.map((option) => (
      <button
        type="button"
        class="chip"
        data-value={option.value}
        aria-pressed="false"
      >
        {option.color && (
          <span
            class="w-2 h-2 rounded-full shrink-0"
            style={`background-color: ${option.color}`}
            aria-hidden="true"
          ></span>
        )}
        {option.label}
      </button>
    ))}
  </div>
</div>

<style>
  .filter-chips {
    display: flex;
    align-items: center;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    white-space: nowrap;
    border: 1px solid var(--color-border-default);
    background: var(--color-bg-surface);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 150ms ease-out;
  }

  .chip:hover {
    border-color: var(--color-border-emphasis);
    color: var(--color-text-primary);
    background: var(--color-bg-elevated);
  }

  .chip:focus-visible {
    outline: 2px solid var(--color-sas-blue);
    outline-offset: 2px;
  }

  .chip--active,
  .chip[aria-pressed="true"] {
    background: var(--color-sas-blue);
    border-color: var(--color-sas-blue);
    color: #ffffff;
  }

  .chip--active:hover,
  .chip[aria-pressed="true"]:hover {
    background: var(--color-sas-blue-hover);
    border-color: var(--color-sas-blue-hover);
    color: #ffffff;
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  // Filter chip interaction logic
  document.addEventListener('DOMContentLoaded', () => {
    const filterGroups = document.querySelectorAll<HTMLElement>('.filter-chips');

    filterGroups.forEach((group) => {
      const chips = group.querySelectorAll<HTMLButtonElement>('.chip');
      const filterKey = group.dataset.filterKey;

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          const value = chip.dataset.value;

          if (value === 'all') {
            // Deactivate all others, activate "All"
            chips.forEach((c) => {
              c.classList.remove('chip--active');
              c.setAttribute('aria-pressed', 'false');
            });
            chip.classList.add('chip--active');
            chip.setAttribute('aria-pressed', 'true');
          } else {
            // Deactivate "All" chip
            const allChip = group.querySelector<HTMLButtonElement>('[data-value="all"]');
            if (allChip) {
              allChip.classList.remove('chip--active');
              allChip.setAttribute('aria-pressed', 'false');
            }

            // Toggle this chip
            const isActive = chip.classList.contains('chip--active');
            if (isActive) {
              chip.classList.remove('chip--active');
              chip.setAttribute('aria-pressed', 'false');

              // If no chips are active, re-activate "All"
              const anyActive = group.querySelector('.chip--active');
              if (!anyActive && allChip) {
                allChip.classList.add('chip--active');
                allChip.setAttribute('aria-pressed', 'true');
              }
            } else {
              chip.classList.add('chip--active');
              chip.setAttribute('aria-pressed', 'true');
            }
          }

          // Dispatch filter event
          const activeChips = group.querySelectorAll<HTMLButtonElement>('.chip--active');
          const activeValues = Array.from(activeChips).map((c) => c.dataset.value || 'all');

          window.dispatchEvent(
            new CustomEvent('filter-change', {
              detail: { key: filterKey, values: activeValues },
            })
          );
        });
      });
    });
  });
</script>
