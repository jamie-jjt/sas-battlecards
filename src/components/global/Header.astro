---
import SearchTrigger from '@components/search/SearchTrigger.astro';
import ThemeToggle from '@components/global/ThemeToggle.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<header class="fixed top-0 left-0 right-0 z-40 h-14 bg-bg-surface border-b border-border-default backdrop-blur-sm no-print">
  <div class="h-full max-w-7xl mx-auto px-4 flex items-center justify-between">
    <a href="/sas-battlecards/" class="flex items-center gap-2 text-text-primary font-semibold text-lg no-underline">
      <span class="text-sas-blue">⚔️</span>
      <span>SAS Battle Cards</span>
    </a>
    <nav class="hidden md:flex items-center gap-5 text-sm" aria-label="Main navigation">
      <a href="/sas-battlecards/battlecards/" class:list={["text-text-secondary hover:text-text-primary transition-colors", { "text-text-primary font-medium": currentPath.includes('/battlecards') }]}>Battle Cards</a>
      <a href="/sas-battlecards/wizard/" class:list={["text-text-secondary hover:text-text-primary transition-colors", { "text-text-primary font-medium": currentPath.includes('/wizard') }]}>Wizard</a>
      <a href="/sas-battlecards/scoping/" class:list={["text-text-secondary hover:text-text-primary transition-colors", { "text-text-primary font-medium": currentPath.includes('/scoping') }]}>Scoping</a>
      <a href="/sas-battlecards/regulations/" class:list={["text-text-secondary hover:text-text-primary transition-colors", { "text-text-primary font-medium": currentPath.includes('/regulations') }]}>Regulations</a>
      <a href="/sas-battlecards/solutions/" class:list={["text-text-secondary hover:text-text-primary transition-colors", { "text-text-primary font-medium": currentPath.includes('/solutions') }]}>Solutions</a>
      <div class="relative group">
        <button class="text-text-secondary hover:text-text-primary transition-colors cursor-pointer flex items-center gap-1" type="button">
          More
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <div class="absolute right-0 top-full mt-1 w-48 rounded-lg border border-border-default bg-bg-surface shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
          <a href="/sas-battlecards/objections/" class="block px-4 py-2 text-sm text-text-secondary hover:text-text-primary hover:bg-bg-elevated rounded-t-lg transition-colors">Objections</a>
          <a href="/sas-battlecards/better-together/" class="block px-4 py-2 text-sm text-text-secondary hover:text-text-primary hover:bg-bg-elevated rounded-b-lg transition-colors">Better Together</a>
        </div>
      </div>
    </nav>
    <div class="flex items-center gap-2">
      <SearchTrigger />
      <ThemeToggle />
    </div>
  </div>
</header>
