---
/**
 * SearchModal — Cmd+K search overlay
 * Client-side search against a hardcoded JSON index.
 * Phase 2 will replace with Pagefind.
 */
const base = import.meta.env.BASE_URL;
---

<div
  id="search-modal"
  class="fixed inset-0 z-50 hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Search"
>
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-bg-base/80 backdrop-blur-sm" data-search-backdrop></div>

  <!-- Modal panel -->
  <div class="relative mx-auto mt-[10vh] w-full max-w-xl px-4">
    <div class="rounded-xl border border-border-default bg-bg-surface shadow-2xl overflow-hidden">
      <!-- Search input -->
      <div class="flex items-center gap-3 border-b border-border-default px-4 py-3">
        <svg class="h-5 w-5 shrink-0 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          id="search-input"
          type="text"
          class="flex-1 bg-transparent text-text-primary placeholder-text-muted outline-none text-base"
          placeholder="Search battle cards, solutions, regulations..."
          autocomplete="off"
          spellcheck="false"
        />
        <kbd class="hidden sm:inline-flex items-center rounded border border-border-default bg-bg-base px-1.5 py-0.5 text-xs font-mono text-text-muted">
          Esc
        </kbd>
      </div>

      <!-- Results -->
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2">
        <div id="search-empty" class="hidden px-4 py-8 text-center text-text-muted text-sm">
          No results found
        </div>
        <div id="search-hint" class="px-4 py-8 text-center text-text-muted text-sm">
          Start typing to search...
        </div>
        <div id="search-list" class="space-y-1"></div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ base }}>
  // Search index — hardcoded for MVP. Phase 2 will use Pagefind.
  const SEARCH_INDEX = [
    { title: 'Databricks', type: 'Battle Card', description: 'ML Platform — High threat competitor in advanced analytics', url: `${base}/battlecards/databricks/` },
    { title: 'Microsoft', type: 'Battle Card', description: 'Cloud Data — Azure ML, Fabric, Synapse ecosystem', url: `${base}/battlecards/microsoft/` },
    { title: 'FICO', type: 'Battle Card', description: 'Fraud & FinCrime — Decision management and scoring', url: `${base}/battlecards/fico/` },
    { title: 'NICE Actimize', type: 'Battle Card', description: 'Fraud & FinCrime — AML and financial crime detection', url: `${base}/battlecards/nice-actimize/` },
    { title: 'Power BI', type: 'Battle Card', description: 'BI & Visualization — Microsoft reporting and dashboards', url: `${base}/battlecards/powerbi/` },
    { title: 'Python/R Open Source', type: 'Battle Card', description: 'Open Source — Community-driven analytics ecosystem', url: `${base}/battlecards/opensource/` },
    { title: 'Dataiku', type: 'Battle Card', description: 'ML Platform — Collaborative data science platform', url: `${base}/battlecards/dataiku/` },
    { title: 'Palantir', type: 'Battle Card', description: 'ML Platform — Data integration and AI platform', url: `${base}/battlecards/palantir/` },
    { title: 'AWS (SageMaker)', type: 'Battle Card', description: 'Cloud Data — SageMaker, Bedrock, QuickSight', url: `${base}/battlecards/aws/` },
    { title: 'Google Cloud (Vertex AI)', type: 'Battle Card', description: 'Cloud Data — Vertex AI, BigQuery, Gemini', url: `${base}/battlecards/google/` },
    { title: 'Snowflake', type: 'Battle Card', description: 'Data Prep — Cloud data warehouse and Snowpark ML', url: `${base}/battlecards/snowflake/` },
    { title: 'Feedzai', type: 'Battle Card', description: 'Fraud & FinCrime — Cloud-native fraud detection for fintechs', url: `${base}/battlecards/feedzai/` },
    { title: 'SymphonyAI', type: 'Battle Card', description: 'Fraud & FinCrime — AI-native AML/fraud (ex-NICE Actimize)', url: `${base}/battlecards/symphonyai/` },
    { title: 'Tookitaki', type: 'Battle Card', description: 'Fraud & FinCrime — Singapore AML startup, federated learning', url: `${base}/battlecards/tookitaki/` },
    { title: 'All Battle Cards', type: 'Navigation', description: 'Browse all competitive battle cards', url: `${base}/battlecards/` },
    { title: 'Quick Prep Wizard', type: 'Tool', description: 'Generate a meeting prep sheet in 60 seconds', url: `${base}/wizard/` },
    { title: 'BSP Circular 1213', type: 'Regulation', description: 'Fraud Management System deadline — June 2026', url: `${base}/regulations/bsp-1213/` },
    { title: 'AFASA', type: 'Regulation', description: 'Anti-Financial Account Scamming Act', url: `${base}/regulations/afasa/` },
    { title: 'AMLA', type: 'Regulation', description: 'Anti-Money Laundering Act', url: `${base}/regulations/amla/` },
    { title: 'BSP Circular 1112', type: 'Regulation', description: 'Model Risk Management Guidelines', url: `${base}/regulations/bsp-1112/` },
    { title: 'Data Privacy Act', type: 'Regulation', description: 'DPA — RA 10173 Data Privacy', url: `${base}/regulations/dpa/` },
    { title: 'IC RBC2', type: 'Regulation', description: 'Insurance Commission Risk-Based Capital', url: `${base}/regulations/ic-rbc2/` },
    { title: 'Scoping Questions', type: 'Tool', description: 'Industry-specific discovery questions for meetings', url: `${base}/scoping/` },
    { title: 'Banking Scoping', type: 'Scoping', description: 'Fraud Management + Model Governance questions', url: `${base}/scoping/banking/` },
    { title: 'Insurance Scoping', type: 'Scoping', description: 'Claims Fraud + IFRS 17 questions', url: `${base}/scoping/insurance/` },
    { title: 'Telco Scoping', type: 'Scoping', description: 'Churn Prevention + Revenue Assurance questions', url: `${base}/scoping/telco/` },
    { title: 'Government Scoping', type: 'Scoping', description: 'Fraud Prevention + Tax Analytics questions', url: `${base}/scoping/government/` },
    { title: 'Retail Scoping', type: 'Scoping', description: 'Forecasting + Customer Intelligence questions', url: `${base}/scoping/retail/` },
    { title: 'Healthcare Scoping', type: 'Scoping', description: 'Clinical Trials + Drug Safety questions', url: `${base}/scoping/healthcare/` },
    { title: 'Objection Handling', type: 'Tool', description: 'AREC framework responses for common objections', url: `${base}/objections/` },
    { title: 'Better Together', type: 'Navigation', description: 'Partner integration architectures', url: `${base}/better-together/` },
    { title: 'SAS + Databricks', type: 'Better Together', description: 'Data engineering + governed analytics architecture', url: `${base}/better-together/databricks/` },
    { title: 'SAS + AWS', type: 'Better Together', description: 'Cloud infrastructure + SAS Viya on EKS', url: `${base}/better-together/aws/` },
    { title: 'SAS + Microsoft', type: 'Better Together', description: 'Azure integration + Fabric + SAS Viya on AKS', url: `${base}/better-together/microsoft/` },
    { title: 'Fraud Management', type: 'Solution', description: 'Real-time fraud detection and prevention', url: `${base}/solutions/fraud-management/` },
    { title: 'Model Manager', type: 'Solution', description: 'Model governance and lifecycle management', url: `${base}/solutions/model-manager/` },
    { title: 'Visual Analytics', type: 'Solution', description: 'Self-service BI and data exploration', url: `${base}/solutions/visual-analytics/` },
    { title: 'Anti-Money Laundering', type: 'Solution', description: 'AML/CFT compliance and monitoring', url: `${base}/solutions/anti-money-laundering/` },
    { title: 'Risk Management', type: 'Solution', description: 'Enterprise risk and capital management', url: `${base}/solutions/risk-management/` },
    { title: 'Intelligent Decisioning', type: 'Solution', description: 'Real-time rules + ML decisioning engine', url: `${base}/solutions/intelligent-decisioning/` },
    { title: 'Sizing Guide', type: 'Tool', description: 'SAS Viya infrastructure sizing profiles', url: `${base}/sizing/` },
    { title: 'Compare Competitors', type: 'Tool', description: 'Side-by-side competitor comparison generator', url: `${base}/compare/` },
    { title: 'Meeting Notes', type: 'Tool', description: 'Structured meeting notes template with Markdown export', url: `${base}/notes/` },
    { title: 'Win/Loss Tracker', type: 'Tool', description: 'Track competitive outcomes in localStorage', url: `${base}/tracker/` },
    { title: 'Competitive Intel', type: 'Tool', description: 'Latest competitive moves and market intelligence', url: `${base}/intel/` },
    { title: 'How to Use', type: 'Navigation', description: 'Guide to using SAS Battle Cards effectively', url: `${base}/help/` },
  ];

  const modal = document.getElementById('search-modal');
  const input = document.getElementById('search-input');
  const resultsList = document.getElementById('search-list');
  const emptyState = document.getElementById('search-empty');
  const hintState = document.getElementById('search-hint');
  let activeIndex = -1;

  function openSearch() {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    input.value = '';
    input.focus();
    renderResults([]);
    showHint();
  }

  function closeSearch() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    activeIndex = -1;
  }

  function showHint() {
    hintState.classList.remove('hidden');
    emptyState.classList.add('hidden');
    resultsList.innerHTML = '';
  }

  function showEmpty() {
    hintState.classList.add('hidden');
    emptyState.classList.remove('hidden');
    resultsList.innerHTML = '';
  }

  function search(query) {
    if (!query.trim()) {
      showHint();
      return;
    }
    const q = query.toLowerCase();
    const results = SEARCH_INDEX.filter(item =>
      item.title.toLowerCase().includes(q) ||
      item.description.toLowerCase().includes(q) ||
      item.type.toLowerCase().includes(q)
    );
    if (results.length === 0) {
      showEmpty();
    } else {
      renderResults(results);
    }
  }

  function renderResults(results) {
    hintState.classList.add('hidden');
    emptyState.classList.add('hidden');
    activeIndex = -1;

    // Group by type
    const grouped = {};
    results.forEach(r => {
      if (!grouped[r.type]) grouped[r.type] = [];
      grouped[r.type].push(r);
    });

    let html = '';
    Object.entries(grouped).forEach(([type, items]) => {
      html += `<div class="px-2 pt-2 pb-1 text-xs font-semibold text-text-muted uppercase tracking-wider">${type}</div>`;
      items.forEach((item, i) => {
        html += `
          <a href="${item.url}" class="search-result flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors hover:bg-bg-elevated focus:bg-bg-elevated outline-none" data-index="${i}">
            <span class="inline-flex items-center rounded-md bg-bg-overlay px-2 py-0.5 text-xs font-medium text-text-secondary">${item.type}</span>
            <span class="flex-1 min-w-0">
              <span class="block font-medium text-text-primary truncate">${item.title}</span>
              <span class="block text-text-muted text-xs truncate">${item.description}</span>
            </span>
            <svg class="h-4 w-4 shrink-0 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        `;
      });
    });
    resultsList.innerHTML = html;
  }

  function getResultElements() {
    return resultsList.querySelectorAll('.search-result');
  }

  function setActiveResult(index) {
    const items = getResultElements();
    items.forEach(el => el.classList.remove('bg-bg-elevated'));
    if (index >= 0 && index < items.length) {
      activeIndex = index;
      items[index].classList.add('bg-bg-elevated');
      items[index].scrollIntoView({ block: 'nearest' });
    }
  }

  // Event listeners
  input?.addEventListener('input', (e) => search(e.target.value));

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    // Open with Cmd+K / Ctrl+K
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (modal.classList.contains('hidden')) {
        openSearch();
      } else {
        closeSearch();
      }
      return;
    }

    // Only handle these when modal is open
    if (modal.classList.contains('hidden')) return;

    if (e.key === 'Escape') {
      e.preventDefault();
      closeSearch();
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      const items = getResultElements();
      if (items.length > 0) {
        setActiveResult(Math.min(activeIndex + 1, items.length - 1));
      }
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (activeIndex > 0) {
        setActiveResult(activeIndex - 1);
      }
    } else if (e.key === 'Enter') {
      e.preventDefault();
      const items = getResultElements();
      if (activeIndex >= 0 && items[activeIndex]) {
        window.location.href = items[activeIndex].getAttribute('href');
      }
    }
  });

  // Close on backdrop click
  document.querySelector('[data-search-backdrop]')?.addEventListener('click', closeSearch);

  // Listen for search triggers
  document.querySelectorAll('[data-search-trigger]').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      openSearch();
    });
  });
</script>
