---
import Badge from '@components/ui/Badge.astro';
import ThreatBadge from '@components/ui/ThreatBadge.astro';
import type { Category, ThreatLevel, Priority } from '@lib/types';

interface Props {
  slug: string;
  name: string;
  category: Category;
  threatLevel: ThreatLevel;
  tagline: string;
  lastUpdated: string;
  priority: Priority;
}

const { slug, name, category, threatLevel, tagline, lastUpdated, priority } = Astro.props;

const categoryBorderColors: Record<string, string> = {
  'ml-platform': 'border-l-cat-ml',
  'cloud-data': 'border-l-cat-cloud',
  'fraud-fincrime': 'border-l-cat-fraud',
  'grc-risk': 'border-l-cat-grc',
  'bi-visualization': 'border-l-cat-bi',
  'data-prep': 'border-l-cat-prep',
  'open-source': 'border-l-cat-oss',
};

const categoryGlowColors: Record<string, string> = {
  'ml-platform': 'hover:shadow-cat-ml/20',
  'cloud-data': 'hover:shadow-cat-cloud/20',
  'fraud-fincrime': 'hover:shadow-cat-fraud/20',
  'grc-risk': 'hover:shadow-cat-grc/20',
  'bi-visualization': 'hover:shadow-cat-bi/20',
  'data-prep': 'hover:shadow-cat-prep/20',
  'open-source': 'hover:shadow-cat-oss/20',
};

const borderColor = categoryBorderColors[category] ?? 'border-l-border-default';
const glowColor = categoryGlowColors[category] ?? '';
const isP1 = priority === 'P1';
---

<a
  href={`/sas-battlecards/battlecards/${slug}/`}
  class:list={[
    "group block rounded-lg border border-border-default bg-bg-surface",
    "border-l-4 transition-all duration-200 ease-out",
    "hover:scale-[1.01] hover:border-border-emphasis hover:shadow-lg",
    "focus-visible:outline-2 focus-visible:outline-sas-blue focus-visible:outline-offset-2",
    borderColor,
    glowColor,
    isP1 && "ring-1 ring-sas-blue/10"
  ]}
  data-category={category}
  data-threat={threatLevel}
>
  <div class="p-4 sm:p-5">
    <!-- Header row: name + badges -->
    <div class="flex items-start justify-between gap-3 mb-2">
      <h3 class="font-semibold text-text-primary text-base group-hover:text-sas-blue transition-colors">
        {name}
      </h3>
      <div class="flex items-center gap-2 shrink-0">
        {isP1 && (
          <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-sas-blue/15 text-sas-blue uppercase tracking-wider">
            P1
          </span>
        )}
        <ThreatBadge level={threatLevel} />
      </div>
    </div>

    <!-- Tagline -->
    <p class="text-sm text-text-secondary line-clamp-2 mb-3">
      {tagline}
    </p>

    <!-- Footer: category badge + last updated -->
    <div class="flex items-center justify-between gap-2">
      <Badge variant="category" value={category} category={category} />
      <span class="text-xs text-text-muted">
        Updated {new Date(lastUpdated).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
      </span>
    </div>
  </div>
</a>
