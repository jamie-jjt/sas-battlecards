---
import ThreatBadge from '@components/ui/ThreatBadge.astro';

interface Props {
  slug: string;
  name: string;
  category: string;
  threatLevel: 'high' | 'medium' | 'low';
}

const { slug, name, category, threatLevel } = Astro.props;

const categoryColors: Record<string, string> = {
  'ml-platform': 'border-l-cat-ml',
  'cloud-data': 'border-l-cat-cloud',
  'fraud-fincrime': 'border-l-cat-fraud',
  'grc-risk': 'border-l-cat-grc',
  'bi-visualization': 'border-l-cat-bi',
  'data-prep': 'border-l-cat-prep',
  'open-source': 'border-l-cat-oss',
};

const borderColor = categoryColors[category] || 'border-l-border-default';
const base = import.meta.env.BASE_URL;
---

<a
  href={`${base}/battlecards/${slug}/`}
  class={`group block rounded-lg border border-border-default bg-bg-surface p-4 border-l-4 ${borderColor} transition-all duration-150 hover:border-border-emphasis hover:bg-bg-elevated`}
>
  <div class="flex items-center justify-between">
    <h3 class="font-semibold text-text-primary group-hover:text-sas-blue transition-colors">{name}</h3>
    <ThreatBadge level={threatLevel} />
  </div>
  <p class="mt-1 text-xs text-text-muted capitalize">{category.replace(/-/g, ' ')}</p>
</a>
