---
import type { Industry } from '@lib/types';

interface Props {
  slug: string;
  name: string;
  issuingBody: string;
  complianceDeadline: string | null;
  summary: string;
  industries: Industry[];
}

const { slug, name, issuingBody, complianceDeadline, summary, industries } = Astro.props;

// Countdown calculation
let daysRemaining: number | null = null;
let urgencyClass = '';
let urgencyBgClass = '';
let urgencyBorderClass = '';

if (complianceDeadline) {
  const deadlineDate = new Date(complianceDeadline);
  const now = new Date();
  const diffMs = deadlineDate.getTime() - now.getTime();
  daysRemaining = Math.max(0, Math.ceil(diffMs / (1000 * 60 * 60 * 24)));

  if (daysRemaining <= 90) {
    urgencyClass = 'text-danger';
    urgencyBgClass = 'bg-danger/10';
    urgencyBorderClass = 'border-l-danger';
  } else if (daysRemaining <= 180) {
    urgencyClass = 'text-warning';
    urgencyBgClass = 'bg-warning/10';
    urgencyBorderClass = 'border-l-warning';
  } else if (daysRemaining <= 365) {
    urgencyClass = 'text-info';
    urgencyBgClass = 'bg-info/10';
    urgencyBorderClass = 'border-l-info';
  } else {
    urgencyClass = 'text-text-muted';
    urgencyBgClass = 'bg-bg-elevated';
    urgencyBorderClass = 'border-l-border-emphasis';
  }
} else {
  urgencyBorderClass = 'border-l-success';
}

const industryLabels: Record<string, string> = {
  banking: 'Banking',
  insurance: 'Insurance',
  telco: 'Telco',
  government: 'Government',
  retail: 'Retail',
  healthcare: 'Healthcare',
  manufacturing: 'Manufacturing',
  energy: 'Energy',
};

const issuingBodyColor: Record<string, string> = {
  'Bangko Sentral ng Pilipinas (BSP)': 'bg-sas-blue/15 text-sas-blue border-sas-blue/30',
  'Congress of the Philippines': 'bg-cat-ml/15 text-cat-ml border-cat-ml/30',
  'Anti-Money Laundering Council (AMLC) / Congress of the Philippines': 'bg-cat-fraud/15 text-cat-fraud border-cat-fraud/30',
  'National Privacy Commission (NPC)': 'bg-cat-grc/15 text-cat-grc border-cat-grc/30',
  'Insurance Commission (IC)': 'bg-cat-bi/15 text-cat-bi border-cat-bi/30',
};

const bodyBadgeClass = issuingBodyColor[issuingBody] ?? 'bg-bg-elevated text-text-secondary border-border-default';

// Short issuing body label
const shortBody = issuingBody.includes('BSP') ? 'BSP' :
  issuingBody.includes('Congress') ? 'Congress' :
  issuingBody.includes('AMLC') ? 'AMLC' :
  issuingBody.includes('NPC') ? 'NPC' :
  issuingBody.includes('Insurance') ? 'IC' : issuingBody;
---

<a
  href={`/sas-battlecards/regulations/${slug}/`}
  class:list={[
    "group block rounded-lg border border-border-default bg-bg-surface",
    "border-l-4 transition-all duration-200 ease-out",
    "hover:scale-[1.01] hover:border-border-emphasis hover:shadow-lg",
    "focus-visible:outline-2 focus-visible:outline-sas-blue focus-visible:outline-offset-2",
    urgencyBorderClass,
  ]}
  data-issuing-body={shortBody.toLowerCase()}
  data-industries={industries.join(',')}
>
  <div class="p-4 sm:p-5">
    <!-- Header row: name + issuing body badge -->
    <div class="flex items-start justify-between gap-3 mb-2">
      <h3 class="font-semibold text-text-primary text-base group-hover:text-sas-blue transition-colors line-clamp-2">
        {name}
      </h3>
      <span class:list={["inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium border shrink-0", bodyBadgeClass]}>
        {shortBody}
      </span>
    </div>

    <!-- Summary -->
    <p class="text-sm text-text-secondary line-clamp-2 mb-3">
      {summary}
    </p>

    <!-- Countdown or "In Effect" badge -->
    {daysRemaining !== null ? (
      <div class:list={["rounded-md px-3 py-2 mb-3", urgencyBgClass]}>
        <div class="flex items-center justify-between">
          <span class:list={["text-xs font-medium", urgencyClass]}>
            ⏱ {daysRemaining} days until deadline
          </span>
          <span class="text-xs text-text-muted">
            {new Date(complianceDeadline!).toLocaleDateString('en-PH', { month: 'short', day: 'numeric', year: 'numeric' })}
          </span>
        </div>
      </div>
    ) : (
      <div class="rounded-md px-3 py-2 mb-3 bg-success/10">
        <span class="text-xs font-medium text-success">✓ In effect — ongoing compliance required</span>
      </div>
    )}

    <!-- Industry chips -->
    <div class="flex flex-wrap gap-1">
      {industries.map((ind) => (
        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-bg-elevated text-text-muted border border-border-default">
          {industryLabels[ind] ?? ind}
        </span>
      ))}
    </div>
  </div>
</a>
