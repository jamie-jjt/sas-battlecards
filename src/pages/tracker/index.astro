---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/global/Breadcrumb.astro';
import { getCollection } from 'astro:content';

const battlecards = await getCollection('battlecards');
const competitors = battlecards.map((bc) => ({ slug: bc.data.slug, name: bc.data.name }));

const industries = [
  { value: 'banking', label: 'Banking' },
  { value: 'insurance', label: 'Insurance' },
  { value: 'telco', label: 'Telco' },
  { value: 'government', label: 'Government' },
  { value: 'retail', label: 'Retail' },
  { value: 'healthcare', label: 'Healthcare' },
  { value: 'manufacturing', label: 'Manufacturing' },
  { value: 'energy', label: 'Energy' },
];

const useCases = [
  'Fraud Management',
  'Anti-Money Laundering',
  'Credit Risk',
  'Advanced Analytics',
  'Model Governance',
  'Real-Time Decisioning',
  'Customer Intelligence',
  'Data Management',
  'Other',
];
---

<BaseLayout title="Win/Loss Tracker">
  <div class="mx-auto max-w-7xl px-4 py-8 space-y-8">
    <Breadcrumb items={[{ label: 'Win/Loss Tracker' }]} />

    <div class="space-y-2">
      <h1 class="text-2xl font-bold text-text-primary">Win/Loss Tracker</h1>
      <p class="text-text-secondary max-w-2xl">
        Log competitive outcomes to track patterns over time. All data stored locally in your browser.
      </p>
    </div>

    <!-- Stats Summary -->
    <div id="stats-panel" class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="rounded-lg border border-border-default bg-bg-surface p-4 text-center">
        <p class="text-2xl font-bold text-success" id="stat-wins">0</p>
        <p class="text-xs text-text-muted">Wins</p>
      </div>
      <div class="rounded-lg border border-border-default bg-bg-surface p-4 text-center">
        <p class="text-2xl font-bold text-danger" id="stat-losses">0</p>
        <p class="text-xs text-text-muted">Losses</p>
      </div>
      <div class="rounded-lg border border-border-default bg-bg-surface p-4 text-center">
        <p class="text-2xl font-bold text-warning" id="stat-inprogress">0</p>
        <p class="text-xs text-text-muted">In Progress</p>
      </div>
      <div class="rounded-lg border border-border-default bg-bg-surface p-4 text-center">
        <p class="text-2xl font-bold text-sas-blue" id="stat-winrate">0%</p>
        <p class="text-xs text-text-muted">Win Rate</p>
      </div>
    </div>

    <!-- Add Deal Form -->
    <details class="rounded-lg border border-border-default bg-bg-surface overflow-hidden group" id="add-deal-form">
      <summary class="px-6 py-4 cursor-pointer select-none flex items-center justify-between hover:bg-bg-elevated transition-colors list-none [&::-webkit-details-marker]:hidden">
        <h2 class="text-sm font-semibold text-text-primary uppercase tracking-wider">+ Log New Deal</h2>
        <svg class="w-4 h-4 text-text-muted transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </summary>
      <div class="px-6 pb-6 pt-2 border-t border-border-muted space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div>
            <label for="deal-date" class="block text-xs font-medium text-text-muted mb-1">Date</label>
            <input type="date" id="deal-date" class="w-full rounded-md border border-border-default bg-bg-base px-3 py-2 text-sm text-text-primary focus:border-sas-blue focus:outline-none" />
          </div>
          <div>
            <label for="deal-customer" class="block text-xs font-medium text-text-muted mb-1">Customer</label>
            <input type="text" id="deal-customer" placeholder="Customer name" class="w-full rounded-md border border-border-default bg-bg-base px-3 py-2 text-sm text-text-primary placeholder-text-muted focus:border-sas-blue focus:outline-none" />
          </div>
          <div>
            <label for="deal-industry" class="block text-xs font-medium text-text-muted mb-1">Industry</label>
            <select id="deal-industry" class="w-full rounded-md border border-border-default bg-bg-base px-3 py-2 text-sm text-text-primary focus:border-sas-blue focus:outline-none">
              <option value="">Select...</option>
              {industries.map((ind) => <option value={ind.value}>{ind.label}</option>)}
            </select>
          </div>
          <div>
            <label for="deal-competitor" class="block text-xs font-medium text-text-muted mb-1">Competitor</label>
            <select id="deal-competitor" class="w-full rounded-md border border-border-default bg-bg-base px-3 py-2 text-sm text-text-primary focus:border-sas-blue focus:outline-none">
              <option value="">Select...</option>
              {competitors.map((c) => <option value={c.slug}>{c.name}</option>)}
            </select>
          </div>
          <div>
            <label for="deal-usecase" class="block text-xs font-medium text-text-muted mb-1">Use Case</label>
            <select id="deal-usecase" class="w-full rounded-md border border-border-default bg-bg-base px-3 py-2 text-sm text-text-primary focus:border-sas-blue focus:outline-none">
              <option value="">Select...</option>
              {useCases.map((uc) => <option value={uc}>{uc}</option>)}
            </select>
          </div>
          <div>
            <label for="deal-outcome" class="block text-xs font-medium text-text-muted mb-1">Outcome</label>
            <select id="deal-outcome" class="w-full rounded-md border border-border-default bg-bg-base px-3 py-2 text-sm text-text-primary focus:border-sas-blue focus:outline-none">
              <option value="">Select...</option>
              <option value="win">Win</option>
              <option value="loss">Loss</option>
              <option value="in-progress">In Progress</option>
            </select>
          </div>
          <div>
            <label for="deal-size" class="block text-xs font-medium text-text-muted mb-1">Deal Size (optional)</label>
            <input type="text" id="deal-size" placeholder="e.g., ₱15M" class="w-full rounded-md border border-border-default bg-bg-base px-3 py-2 text-sm text-text-primary placeholder-text-muted focus:border-sas-blue focus:outline-none" />
          </div>
          <div class="sm:col-span-2">
            <label for="deal-notes" class="block text-xs font-medium text-text-muted mb-1">Notes</label>
            <input type="text" id="deal-notes" placeholder="Key takeaway or reason for win/loss" class="w-full rounded-md border border-border-default bg-bg-base px-3 py-2 text-sm text-text-primary placeholder-text-muted focus:border-sas-blue focus:outline-none" />
          </div>
        </div>
        <button type="button" id="btn-save-deal" class="px-4 py-2 text-sm font-medium rounded-lg bg-sas-blue text-white hover:bg-sas-blue-hover transition-colors cursor-pointer">
          Save Deal
        </button>
      </div>
    </details>

    <!-- Filters -->
    <div class="flex flex-wrap items-center gap-3">
      <select id="filter-competitor" class="rounded-md border border-border-default bg-bg-surface px-3 py-1.5 text-xs text-text-secondary focus:border-sas-blue focus:outline-none">
        <option value="">All Competitors</option>
        {competitors.map((c) => <option value={c.slug}>{c.name}</option>)}
      </select>
      <select id="filter-industry" class="rounded-md border border-border-default bg-bg-surface px-3 py-1.5 text-xs text-text-secondary focus:border-sas-blue focus:outline-none">
        <option value="">All Industries</option>
        {industries.map((ind) => <option value={ind.value}>{ind.label}</option>)}
      </select>
      <select id="filter-outcome" class="rounded-md border border-border-default bg-bg-surface px-3 py-1.5 text-xs text-text-secondary focus:border-sas-blue focus:outline-none">
        <option value="">All Outcomes</option>
        <option value="win">Wins</option>
        <option value="loss">Losses</option>
        <option value="in-progress">In Progress</option>
      </select>
    </div>

    <!-- Deals Table -->
    <div class="overflow-x-auto rounded-lg border border-border-default">
      <table class="w-full text-sm">
        <thead class="bg-bg-surface border-b border-border-default">
          <tr>
            <th class="text-left py-2.5 px-3 text-text-muted font-medium">Date</th>
            <th class="text-left py-2.5 px-3 text-text-muted font-medium">Customer</th>
            <th class="text-left py-2.5 px-3 text-text-muted font-medium hidden sm:table-cell">Industry</th>
            <th class="text-left py-2.5 px-3 text-text-muted font-medium">Competitor</th>
            <th class="text-left py-2.5 px-3 text-text-muted font-medium hidden md:table-cell">Use Case</th>
            <th class="text-left py-2.5 px-3 text-text-muted font-medium">Outcome</th>
            <th class="text-left py-2.5 px-3 text-text-muted font-medium">Actions</th>
          </tr>
        </thead>
        <tbody id="deals-tbody"></tbody>
      </table>
      <div id="deals-empty" class="px-4 py-8 text-center text-text-muted text-sm hidden">
        No deals logged yet. Use the form above to start tracking.
      </div>
    </div>

    <!-- Bottom Actions -->
    <div class="flex flex-wrap gap-3">
      <button type="button" id="btn-export-csv" class="px-4 py-2 text-sm font-medium rounded-lg border border-border-default text-text-secondary hover:text-text-primary hover:bg-bg-elevated transition-colors cursor-pointer">
        📥 Export as CSV
      </button>
      <button type="button" id="btn-clear-all" class="px-4 py-2 text-sm font-medium rounded-lg border border-danger/30 text-danger hover:bg-danger/10 transition-colors cursor-pointer">
        🗑️ Clear All Data
      </button>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ competitors }}>
  const STORAGE_KEY = 'sas-battlecards-tracker';
  const competitorMap = Object.fromEntries(competitors.map((c) => [c.slug, c.name]));

  function getDeals() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    } catch { return []; }
  }

  function saveDeals(deals) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(deals));
  }

  function updateStats() {
    const deals = getDeals();
    const wins = deals.filter((d) => d.outcome === 'win').length;
    const losses = deals.filter((d) => d.outcome === 'loss').length;
    const inProgress = deals.filter((d) => d.outcome === 'in-progress').length;
    const winRate = wins + losses > 0 ? Math.round((wins / (wins + losses)) * 100) : 0;

    document.getElementById('stat-wins').textContent = String(wins);
    document.getElementById('stat-losses').textContent = String(losses);
    document.getElementById('stat-inprogress').textContent = String(inProgress);
    document.getElementById('stat-winrate').textContent = winRate + '%';
  }

  function renderDeals() {
    const deals = getDeals();
    const filterComp = (document.getElementById('filter-competitor')).value;
    const filterInd = (document.getElementById('filter-industry')).value;
    const filterOut = (document.getElementById('filter-outcome')).value;

    const filtered = deals.filter((d) => {
      if (filterComp && d.competitor !== filterComp) return false;
      if (filterInd && d.industry !== filterInd) return false;
      if (filterOut && d.outcome !== filterOut) return false;
      return true;
    });

    const tbody = document.getElementById('deals-tbody');
    const emptyState = document.getElementById('deals-empty');

    if (filtered.length === 0) {
      tbody.innerHTML = '';
      emptyState.classList.remove('hidden');
      return;
    }

    emptyState.classList.add('hidden');

    const outcomeStyles = {
      win: 'bg-success/15 text-success',
      loss: 'bg-danger/15 text-danger',
      'in-progress': 'bg-warning/15 text-warning',
    };

    tbody.innerHTML = filtered.sort((a, b) => b.date.localeCompare(a.date)).map((deal, i) => `
      <tr class="border-b border-border-muted hover:bg-bg-elevated/50 transition-colors">
        <td class="py-2 px-3 text-text-secondary">${deal.date}</td>
        <td class="py-2 px-3 text-text-primary font-medium">${deal.customer}</td>
        <td class="py-2 px-3 text-text-secondary hidden sm:table-cell">${deal.industry || '-'}</td>
        <td class="py-2 px-3 text-text-secondary">${competitorMap[deal.competitor] || deal.competitor || '-'}</td>
        <td class="py-2 px-3 text-text-secondary hidden md:table-cell">${deal.useCase || '-'}</td>
        <td class="py-2 px-3"><span class="px-2 py-0.5 rounded-full text-xs font-medium ${outcomeStyles[deal.outcome] || ''}">${deal.outcome}</span></td>
        <td class="py-2 px-3"><button type="button" class="text-danger/70 hover:text-danger text-xs cursor-pointer delete-deal" data-index="${deals.indexOf(deal)}">×</button></td>
      </tr>
    `).join('');
  }

  // Save deal
  document.getElementById('btn-save-deal')?.addEventListener('click', () => {
    const date = (document.getElementById('deal-date')).value;
    const customer = (document.getElementById('deal-customer')).value;
    const outcome = (document.getElementById('deal-outcome')).value;

    if (!date || !customer || !outcome) {
      alert('Please fill in Date, Customer, and Outcome.');
      return;
    }

    const deal = {
      id: Date.now().toString(),
      date,
      customer,
      industry: (document.getElementById('deal-industry')).value,
      competitor: (document.getElementById('deal-competitor')).value,
      useCase: (document.getElementById('deal-usecase')).value,
      outcome,
      dealSize: (document.getElementById('deal-size')).value,
      notes: (document.getElementById('deal-notes')).value,
    };

    const deals = getDeals();
    deals.push(deal);
    saveDeals(deals);
    updateStats();
    renderDeals();

    // Reset form
    ['deal-date', 'deal-customer', 'deal-size', 'deal-notes'].forEach((id) => {
      (document.getElementById(id)).value = '';
    });
    ['deal-industry', 'deal-competitor', 'deal-usecase', 'deal-outcome'].forEach((id) => {
      (document.getElementById(id)).selectedIndex = 0;
    });
    (document.getElementById('deal-date')).value = new Date().toISOString().split('T')[0];
  });

  // Delete deal
  document.getElementById('deals-tbody')?.addEventListener('click', (e) => {
    const btn = (e.target).closest('.delete-deal');
    if (!btn) return;
    const index = parseInt(btn.dataset.index);
    const deals = getDeals();
    deals.splice(index, 1);
    saveDeals(deals);
    updateStats();
    renderDeals();
  });

  // Filters
  ['filter-competitor', 'filter-industry', 'filter-outcome'].forEach((id) => {
    document.getElementById(id)?.addEventListener('change', renderDeals);
  });

  // Export CSV
  document.getElementById('btn-export-csv')?.addEventListener('click', () => {
    const deals = getDeals();
    if (deals.length === 0) { alert('No deals to export.'); return; }
    const headers = 'Date,Customer,Industry,Competitor,Use Case,Outcome,Deal Size,Notes';
    const rows = deals.map((d) =>
      `${d.date},"${d.customer}",${d.industry},${competitorMap[d.competitor] || d.competitor},${d.useCase},${d.outcome},"${d.dealSize || ''}","${d.notes || ''}"`
    );
    const csv = [headers, ...rows].join('\n');
    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = `sas-battlecards-tracker-${new Date().toISOString().split('T')[0]}.csv`;
    a.click(); URL.revokeObjectURL(url);
  });

  // Clear all
  document.getElementById('btn-clear-all')?.addEventListener('click', () => {
    if (confirm('This will permanently delete all tracked deals. Are you sure?')) {
      localStorage.removeItem(STORAGE_KEY);
      updateStats();
      renderDeals();
    }
  });

  // Init
  const dateInput = document.getElementById('deal-date');
  if (dateInput) dateInput.value = new Date().toISOString().split('T')[0];
  updateStats();
  renderDeals();
</script>
