---
import BaseLayout from '@layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const dynamicQuestionsJSON = JSON.stringify((await import('../data/dynamic-questions.json')).default.combinations);
---

<BaseLayout title="Meeting Prep Wizard">
  <div class="mx-auto max-w-3xl px-4 py-8">

    <!-- Step Indicator -->
    <nav aria-label="Wizard progress" class="mb-8">
      <ol id="step-indicator" class="flex items-center justify-between gap-2 text-xs sm:text-sm">
        <li data-step="1" class="flex flex-col items-center gap-1 text-sas-blue font-medium">
          <span class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-sas-blue bg-sas-blue text-white text-xs font-bold">1</span>
          <span class="hidden sm:block">Industry</span>
        </li>
        <li class="flex-1 h-0.5 bg-border-default" aria-hidden="true"></li>
        <li data-step="2" class="flex flex-col items-center gap-1 text-text-muted">
          <span class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-border-default text-xs font-bold">2</span>
          <span class="hidden sm:block">Competitor</span>
        </li>
        <li class="flex-1 h-0.5 bg-border-default" aria-hidden="true"></li>
        <li data-step="3" class="flex flex-col items-center gap-1 text-text-muted">
          <span class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-border-default text-xs font-bold">3</span>
          <span class="hidden sm:block">Use Case</span>
        </li>
        <li class="flex-1 h-0.5 bg-border-default" aria-hidden="true"></li>
        <li data-step="4" class="flex flex-col items-center gap-1 text-text-muted">
          <span class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-border-default text-xs font-bold">4</span>
          <span class="hidden sm:block">Meeting</span>
        </li>
        <li class="flex-1 h-0.5 bg-border-default" aria-hidden="true"></li>
        <li data-step="5" class="flex flex-col items-center gap-1 text-text-muted">
          <span class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-border-default text-xs font-bold">5</span>
          <span class="hidden sm:block">Maturity</span>
        </li>
        <li class="flex-1 h-0.5 bg-border-default" aria-hidden="true"></li>
        <li data-step="6" class="flex flex-col items-center gap-1 text-text-muted">
          <span class="flex h-7 w-7 items-center justify-center rounded-full border-2 border-border-default text-xs font-bold">6</span>
          <span class="hidden sm:block">Persona</span>
        </li>
      </ol>
    </nav>

    <!-- Wizard Content -->
    <div id="wizard-content" class="min-h-[400px]">
      <!-- Steps rendered by JS -->
    </div>

    <!-- Navigation -->
    <div id="wizard-nav" class="mt-8 flex items-center justify-between">
      <button id="btn-back" type="button" class="hidden rounded-lg border border-border-default bg-bg-surface px-5 py-2.5 text-sm font-medium text-text-primary transition-colors hover:bg-bg-elevated">
        ← Back
      </button>
      <div></div>
    </div>

  </div>
</BaseLayout>

<script define:vars={{ base, dynamicQuestionsJSON }}>
(function() {
  // ============================================================
  // STATE
  // ============================================================
  const state = {
    step: 1,
    industry: '',
    competitors: [],
    useCase: '',
    meetingType: '',
    maturity: '',
    persona: ''
  };

  // ============================================================
  // DYNAMIC QUESTIONS DATA
  // ============================================================
  const dynamicCombinations = JSON.parse(dynamicQuestionsJSON);

  // ============================================================
  // DATA
  // ============================================================
  const industries = [
    { id: 'banking', label: 'Banking', emoji: '🏦' },
    { id: 'insurance', label: 'Insurance', emoji: '🛡️' },
    { id: 'telco', label: 'Telco', emoji: '📡' },
    { id: 'government', label: 'Government', emoji: '🏛️' },
    { id: 'healthcare', label: 'Healthcare', emoji: '🏥' },
    { id: 'retail', label: 'Retail', emoji: '🛒' },
    { id: 'manufacturing', label: 'Manufacturing', emoji: '🏭' },
    { id: 'energy', label: 'Energy', emoji: '⚡' },
  ];

  const competitors = [
    { id: 'databricks', label: 'Databricks' },
    { id: 'microsoft', label: 'Microsoft' },
    { id: 'dataiku', label: 'Dataiku' },
    { id: 'fico', label: 'FICO' },
    { id: 'nice-actimize', label: 'NICE Actimize' },
    { id: 'powerbi', label: 'Power BI' },
    { id: 'python-r', label: 'Python/R' },
    { id: 'snowflake', label: 'Snowflake' },
    { id: 'aws', label: 'AWS' },
    { id: 'google', label: 'Google' },
    { id: 'none', label: 'None / Unknown' },
  ];

  const useCases = [
    { id: 'fraud-detection', label: 'Fraud Detection', emoji: '🚨' },
    { id: 'aml', label: 'AML / Financial Crime', emoji: '🔍' },
    { id: 'risk-modeling', label: 'Risk Modeling', emoji: '📊' },
    { id: 'customer-analytics', label: 'Customer Analytics', emoji: '👥' },
    { id: 'forecasting', label: 'Forecasting / Planning', emoji: '📈' },
    { id: 'platform-modernization', label: 'Platform Modernization', emoji: '🔄' },
    { id: 'genai-llm', label: 'GenAI / LLM', emoji: '🤖' },
    { id: 'clinical-trials', label: 'Clinical Trials', emoji: '💊' },
    { id: 'supply-chain', label: 'Supply Chain', emoji: '🚛' },
    { id: 'general-ml', label: 'General ML', emoji: '🧠' },
  ];

  const meetingTypes = [
    { id: 'discovery', label: 'Discovery', desc: 'First meeting — learn about them' },
    { id: 'competitive-bakeoff', label: 'Competitive Bake-off / RFP', desc: 'Head-to-head comparison' },
    { id: 'expansion', label: 'Customer Expansion', desc: 'Existing SAS customer, new use case' },
    { id: 'technical-deepdive', label: 'Technical Deep Dive', desc: 'Architecture & integration focus' },
    { id: 'executive-presentation', label: 'Executive Presentation', desc: 'CxO-level, strategic value' },
    { id: 'poc-planning', label: 'POC Planning', desc: 'Scoping a proof of concept' },
  ];

  const maturityLevels = [
    { id: 'L1', label: 'L1 Greenfield', desc: 'No analytics team, Excel/manual processes' },
    { id: 'L2', label: 'L2 Emerging', desc: 'Small team, basic tools (Alteryx, notebooks)' },
    { id: 'L3', label: 'L3 Intermediate', desc: 'Established function, models in production' },
    { id: 'L4', label: 'L4 Advanced', desc: 'Full MLOps, multiple platforms, mature governance' },
  ];

  const personas = [
    { id: 'cto-cdo', label: 'CTO / CDO', emoji: '💻' },
    { id: 'cfo-coo', label: 'CFO / COO', emoji: '📋' },
    { id: 'ciso-cro', label: 'CISO / CRO', emoji: '🔒' },
    { id: 'head-data-science', label: 'Head of Data Science', emoji: '🧬' },
    { id: 'business-unit-leader', label: 'Business Unit Leader', emoji: '👔' },
    { id: 'unknown', label: "I don't know", emoji: '❓' },
  ];

  // Battle card slug to tagline mapping
  const battleCardData = {
    'databricks': { name: 'Databricks', tagline: 'SAS wins on governance, explainability, and regulated-industry depth.' },
    'microsoft': { name: 'Microsoft', tagline: 'SAS wins on advanced analytics depth and model governance at scale.' },
    'dataiku': { name: 'Dataiku', tagline: 'SAS wins on enterprise scalability, regulatory depth, and production hardening.' },
    'fico': { name: 'FICO', tagline: 'SAS wins on ML flexibility, total platform breadth, and cost of ownership.' },
    'nice-actimize': { name: 'NICE Actimize', tagline: 'SAS wins on analytics depth, false positive reduction, and platform openness.' },
    'powerbi': { name: 'Power BI', tagline: 'SAS wins on advanced analytics, forecasting, and governed model deployment.' },
    'opensource': { name: 'Python/R Open Source', tagline: 'SAS wins on production governance, enterprise support, and business user access.' },
    'snowflake': { name: 'Snowflake', tagline: 'SAS wins on governed analytics and real-time decisioning beyond SQL.' },
    'aws': { name: 'AWS (SageMaker)', tagline: 'SAS wins on model governance, business user access, and no cloud lock-in.' },
    'google': { name: 'Google Cloud', tagline: 'SAS wins on enterprise readiness, regulatory depth, and on-prem options.' },
  };

  // Meeting tips by type
  const meetingTips = {
    'discovery': [
      "Listen 80% / talk 20% — this meeting is about learning.",
      "Don't demo unless they ask. Focus on their pain, not your product.",
      "End with: \"Based on what you've shared, here's what I'd recommend as a next step.\"",
      "Map their org chart: who's the economic buyer vs. technical evaluator?",
      "Ask about timelines and budget cycles early — saves wasted effort.",
    ],
    'competitive-bakeoff': [
      "Lead with differentiators, not features. What can SAS do that they can't?",
      "Prepare landmine questions from the relevant battle card.",
      "Know the competitor's pricing model — be ready to reframe cost discussions.",
      "Bring a proof point for every major claim.",
      "Don't trash the competitor — acknowledge strengths, then pivot to gaps.",
    ],
    'expansion': [
      "Reference their existing SAS investment — show you know their environment.",
      "Position the new use case as low incremental risk: same platform, same governance.",
      "Identify a champion in the business unit requesting the new capability.",
      "Show how the new use case complements what they already have (data reuse, shared models).",
    ],
    'technical-deepdive': [
      "Bring architecture diagrams. Show integration points with their existing stack.",
      "Be prepared for tough questions on scalability, latency, and deployment options.",
      "Know the deployment topology: Kubernetes, cloud provider, sizing.",
      "Have a reference architecture ready for their industry vertical.",
    ],
    'executive-presentation': [
      "Lead with business outcomes, not technology. Revenue, risk reduction, efficiency.",
      "Keep it under 20 minutes. Executives value brevity.",
      "One key message: \"SAS helps you [outcome] by [mechanism] with [proof].\"",
      "Have one customer reference story that mirrors their situation.",
      "End with a clear ask: next step, timeline, decision criteria.",
    ],
    'poc-planning': [
      "Define success criteria BEFORE starting. What does a successful POC prove?",
      "Scope tight: 4-6 weeks max. One use case, measurable outcome.",
      "Identify data availability early — data access is the #1 POC blocker.",
      "Agree on evaluation rubric: don't let them move goalposts mid-POC.",
      "Plan the path from POC to production — avoid \"POC purgatory\".",
    ],
  };

  // ============================================================
  // DYNAMIC QUESTION RESOLUTION
  // ============================================================
  function resolveQuestions(currentState) {
    const { industry, useCase, meetingType, maturity, persona } = currentState;

    // 1. Try exact match on all 5 dimensions
    let match = dynamicCombinations.find(c =>
      c.industry === industry &&
      c.useCase === useCase &&
      c.meetingType === meetingType &&
      c.maturity === maturity &&
      c.persona === persona
    );
    if (match) return { combo: match, matchType: 'exact' };

    // 2. Relax persona → 'unknown'
    match = dynamicCombinations.find(c =>
      c.industry === industry &&
      c.useCase === useCase &&
      c.meetingType === meetingType &&
      c.maturity === maturity &&
      c.persona === 'unknown'
    );
    if (match) return { combo: match, matchType: 'relaxed-persona' };

    // 3. Relax maturity (±1 level)
    const maturityOrder = ['L1', 'L2', 'L3', 'L4'];
    const matIdx = maturityOrder.indexOf(maturity);
    const nearbyMaturities = [];
    if (matIdx > 0) nearbyMaturities.push(maturityOrder[matIdx - 1]);
    if (matIdx < maturityOrder.length - 1) nearbyMaturities.push(maturityOrder[matIdx + 1]);

    for (const nearMat of nearbyMaturities) {
      match = dynamicCombinations.find(c =>
        c.industry === industry &&
        c.useCase === useCase &&
        c.meetingType === meetingType &&
        c.maturity === nearMat &&
        (c.persona === persona || c.persona === 'unknown')
      );
      if (match) return { combo: match, matchType: 'relaxed-maturity' };
    }

    // 4. Relax meetingType — try 'discovery' as default
    match = dynamicCombinations.find(c =>
      c.industry === industry &&
      c.useCase === useCase &&
      c.meetingType === 'discovery' &&
      (c.persona === persona || c.persona === 'unknown')
    );
    if (match) return { combo: match, matchType: 'relaxed-meeting' };

    // 5. Try matching just industry + useCase (strongest determinants)
    match = dynamicCombinations.find(c =>
      c.industry === industry &&
      c.useCase === useCase &&
      c.id !== 'combo-fallback'
    );
    if (match) return { combo: match, matchType: 'partial-industry-usecase' };

    // 6. Fallback
    const fallback = dynamicCombinations.find(c => c.id === 'combo-fallback');
    return { combo: fallback, matchType: 'fallback' };
  }

  // ============================================================
  // URL STATE SYNC
  // ============================================================
  function syncStateToURL() {
    const params = new URLSearchParams();
    if (state.industry) params.set('i', state.industry);
    if (state.competitors.length) params.set('c', state.competitors.join(','));
    if (state.useCase) params.set('u', state.useCase);
    if (state.meetingType) params.set('m', state.meetingType);
    if (state.maturity) params.set('l', state.maturity);
    if (state.persona) params.set('p', state.persona);
    params.set('s', String(state.step));
    history.replaceState(null, '', '?' + params.toString());
  }

  function hydrateFromURL() {
    const params = new URLSearchParams(location.search);
    if (params.has('s')) {
      state.step = parseInt(params.get('s')) || 1;
      state.industry = params.get('i') || '';
      state.competitors = (params.get('c') || '').split(',').filter(Boolean);
      state.useCase = params.get('u') || '';
      state.meetingType = params.get('m') || '';
      state.maturity = params.get('l') || '';
      state.persona = params.get('p') || '';
    }
  }

  // ============================================================
  // DOM REFERENCES
  // ============================================================
  const content = document.getElementById('wizard-content');
  const btnBack = document.getElementById('btn-back');
  const stepIndicator = document.getElementById('step-indicator');

  // ============================================================
  // RENDER FUNCTIONS
  // ============================================================
  function renderStep() {
    updateIndicator();
    btnBack.classList.toggle('hidden', state.step === 1);
    syncStateToURL();

    switch(state.step) {
      case 1: renderIndustry(); break;
      case 2: renderCompetitors(); break;
      case 3: renderUseCase(); break;
      case 4: renderMeetingType(); break;
      case 5: renderMaturity(); break;
      case 6: renderPersona(); break;
      case 7: renderPrepSheet(); break;
    }

    if (state.step <= 6) {
      if (window.announce) window.announce('Step ' + state.step + ' of 6');
    } else {
      if (window.announce) window.announce('Prep sheet generated');
    }
  }

  function updateIndicator() {
    const steps = stepIndicator.querySelectorAll('[data-step]');
    steps.forEach(li => {
      const s = parseInt(li.dataset.step);
      const dot = li.querySelector('span:first-child');
      if (s < state.step) {
        li.className = 'flex flex-col items-center gap-1 text-success font-medium';
        dot.className = 'flex h-7 w-7 items-center justify-center rounded-full border-2 border-success bg-success text-white text-xs font-bold';
        dot.textContent = '✓';
      } else if (s === state.step) {
        li.className = 'flex flex-col items-center gap-1 text-sas-blue font-medium';
        dot.className = 'flex h-7 w-7 items-center justify-center rounded-full border-2 border-sas-blue bg-sas-blue text-white text-xs font-bold';
        dot.textContent = s;
      } else {
        li.className = 'flex flex-col items-center gap-1 text-text-muted';
        dot.className = 'flex h-7 w-7 items-center justify-center rounded-full border-2 border-border-default text-xs font-bold';
        dot.textContent = s;
      }
    });

    // Hide indicator on prep sheet
    stepIndicator.parentElement.classList.toggle('hidden', state.step === 7);
  }

  function makeGrid(items, onSelect, selected, multiSelect = false) {
    const cols = items.length > 6 ? 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-4' : 'grid-cols-2 sm:grid-cols-3';
    let html = `<div class="grid ${cols} gap-3">`;
    items.forEach(item => {
      const isSelected = multiSelect
        ? (selected || []).includes(item.id)
        : selected === item.id;
      const selectedClass = isSelected
        ? 'border-sas-blue bg-sas-blue/10 text-sas-blue ring-1 ring-sas-blue'
        : 'border-border-default bg-bg-surface text-text-primary hover:border-border-emphasis hover:bg-bg-elevated';
      html += `
        <button type="button" data-id="${item.id}" class="wizard-option rounded-lg border p-4 text-center transition-all duration-150 cursor-pointer ${selectedClass}">
          ${item.emoji ? `<span class="text-2xl block mb-1">${item.emoji}</span>` : ''}
          <span class="text-sm font-medium block">${item.label}</span>
          ${item.desc ? `<span class="text-xs text-text-muted block mt-1">${item.desc}</span>` : ''}
        </button>
      `;
    });
    html += '</div>';
    return html;
  }

  function renderIndustry() {
    content.innerHTML = `
      <h2 class="text-xl font-bold text-text-primary mb-2">Select Industry</h2>
      <p class="text-sm text-text-secondary mb-6">What sector is the customer in?</p>
      ${makeGrid(industries, null, state.industry)}
    `;
    content.querySelectorAll('.wizard-option').forEach(btn => {
      btn.addEventListener('click', () => {
        state.industry = btn.dataset.id;
        state.step = 2;
        renderStep();
      });
    });
  }

  function renderCompetitors() {
    content.innerHTML = `
      <h2 class="text-xl font-bold text-text-primary mb-2">Competitor / Incumbent</h2>
      <p class="text-sm text-text-secondary mb-6">What platforms are they using or evaluating? <span class="text-text-muted">(Select 1-3)</span></p>
      ${makeGrid(competitors, null, state.competitors, true)}
      <button id="btn-next-comp" type="button" class="mt-6 w-full rounded-lg bg-sas-blue px-5 py-3 font-semibold text-white transition-colors hover:bg-sas-blue-hover disabled:opacity-40 disabled:cursor-not-allowed" ${state.competitors.length === 0 ? 'disabled' : ''}>
        Next →
      </button>
    `;
    content.querySelectorAll('.wizard-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id;
        const idx = state.competitors.indexOf(id);
        if (idx > -1) {
          state.competitors.splice(idx, 1);
        } else if (state.competitors.length < 3) {
          state.competitors.push(id);
        }
        renderCompetitors();
      });
    });
    const nextBtn = document.getElementById('btn-next-comp');
    nextBtn.addEventListener('click', () => {
      if (state.competitors.length > 0) {
        state.step = 3;
        renderStep();
      }
    });
  }

  function renderUseCase() {
    content.innerHTML = `
      <h2 class="text-xl font-bold text-text-primary mb-2">Primary Use Case</h2>
      <p class="text-sm text-text-secondary mb-6">What are they trying to solve?</p>
      ${makeGrid(useCases, null, state.useCase)}
    `;
    content.querySelectorAll('.wizard-option').forEach(btn => {
      btn.addEventListener('click', () => {
        state.useCase = btn.dataset.id;
        state.step = 4;
        renderStep();
      });
    });
  }

  function renderMeetingType() {
    content.innerHTML = `
      <h2 class="text-xl font-bold text-text-primary mb-2">Meeting Type</h2>
      <p class="text-sm text-text-secondary mb-6">What kind of conversation is this?</p>
      ${makeGrid(meetingTypes, null, state.meetingType)}
    `;
    content.querySelectorAll('.wizard-option').forEach(btn => {
      btn.addEventListener('click', () => {
        state.meetingType = btn.dataset.id;
        state.step = 5;
        renderStep();
      });
    });
  }

  function renderMaturity() {
    content.innerHTML = `
      <h2 class="text-xl font-bold text-text-primary mb-2">Customer Maturity</h2>
      <p class="text-sm text-text-secondary mb-6">Where are they on the analytics journey?</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        ${maturityLevels.map(m => {
          const isSelected = state.maturity === m.id;
          const cls = isSelected
            ? 'border-sas-blue bg-sas-blue/10 ring-1 ring-sas-blue'
            : 'border-border-default bg-bg-surface hover:border-border-emphasis hover:bg-bg-elevated';
          return `
            <button type="button" data-id="${m.id}" class="wizard-option rounded-lg border p-5 text-left transition-all duration-150 cursor-pointer ${cls}">
              <span class="text-sm font-bold text-text-primary block">${m.label}</span>
              <span class="text-xs text-text-muted block mt-1">${m.desc}</span>
            </button>
          `;
        }).join('')}
      </div>
    `;
    content.querySelectorAll('.wizard-option').forEach(btn => {
      btn.addEventListener('click', () => {
        state.maturity = btn.dataset.id;
        state.step = 6;
        renderStep();
      });
    });
  }

  function renderPersona() {
    content.innerHTML = `
      <h2 class="text-xl font-bold text-text-primary mb-2">Who Are You Meeting?</h2>
      <p class="text-sm text-text-secondary mb-6">What's the persona of your primary contact?</p>
      ${makeGrid(personas, null, state.persona)}
    `;
    content.querySelectorAll('.wizard-option').forEach(btn => {
      btn.addEventListener('click', () => {
        state.persona = btn.dataset.id;
        state.step = 7;
        renderStep();
      });
    });
  }

  function renderPrepSheet() {
    btnBack.classList.add('hidden');

    // Resolve dynamic questions
    const resolved = resolveQuestions(state);
    const matchedQuestions = resolved.combo ? resolved.combo.questions : [];
    const matchContext = resolved.combo ? resolved.combo.context : '';
    const matchType = resolved.matchType;

    // Get relevant battle cards
    const relevantCards = state.competitors
      .map(c => {
        const slugMap = { 'python-r': 'opensource', 'none': null };
        const slug = slugMap[c] !== undefined ? slugMap[c] : c;
        if (!slug || !battleCardData[slug]) return null;
        return { slug, ...battleCardData[slug] };
      })
      .filter(Boolean);

    // Get tips
    const tips = meetingTips[state.meetingType] || meetingTips['discovery'];

    // Positioning statement
    const positioning = relevantCards.length > 0
      ? relevantCards[0].tagline
      : 'SAS delivers trusted analytics with enterprise governance, regulatory depth, and production scalability that open-source and cloud-native tools cannot match.';

    // Viya tier badge colors
    function tierBadge(tier) {
      const colors = {
        'Standard': 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300',
        'Advanced': 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300',
        'Premium': 'bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300',
        'Any': 'bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300',
      };
      const cls = colors[tier] || colors['Any'];
      return `<span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide ${cls}">${tier}</span>`;
    }

    // Priority indicator
    function priorityLabel(p) {
      if (p === 1) return '<span class="text-[10px] font-bold text-red-500 uppercase">Must Ask</span>';
      if (p === 2) return '<span class="text-[10px] font-bold text-amber-500 uppercase">Should Ask</span>';
      return '<span class="text-[10px] font-bold text-gray-400 uppercase">If Time</span>';
    }

    // Match type label
    function matchLabel(type) {
      const labels = {
        'exact': '✅ Exact match found',
        'relaxed-persona': '🔄 Matched (relaxed persona)',
        'relaxed-maturity': '🔄 Matched (nearby maturity)',
        'relaxed-meeting': '🔄 Matched (default meeting type)',
        'partial-industry-usecase': '⚠️ Partial match (industry + use case)',
        'fallback': '❓ Using universal discovery questions',
      };
      return labels[type] || type;
    }

    content.innerHTML = `
      <div class="space-y-6" id="prep-sheet">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-bold text-text-primary">Your Prep Sheet</h2>
          <div class="flex items-center gap-2 no-print">
            <button id="btn-copy" type="button" class="rounded-lg border border-border-default bg-bg-surface px-3 py-2 text-xs font-medium text-text-primary hover:bg-bg-elevated transition-colors">
              📋 Copy All
            </button>
            <button id="btn-print" type="button" class="rounded-lg border border-border-default bg-bg-surface px-3 py-2 text-xs font-medium text-text-primary hover:bg-bg-elevated transition-colors">
              🖨️ Print
            </button>
            <button id="btn-restart" type="button" class="rounded-lg border border-sas-blue bg-sas-blue/10 px-3 py-2 text-xs font-medium text-sas-blue hover:bg-sas-blue/20 transition-colors">
              ↺ Start Over
            </button>
          </div>
        </div>

        <!-- Summary -->
        <div class="rounded-lg border border-border-default bg-bg-surface p-4">
          <h3 class="text-sm font-semibold text-text-secondary uppercase tracking-wide mb-3">Meeting Context</h3>
          <div class="grid grid-cols-2 gap-3 text-sm sm:grid-cols-3">
            <div>
              <span class="text-text-muted block text-xs">Industry</span>
              <span class="font-medium text-text-primary capitalize">${state.industry}</span>
            </div>
            <div>
              <span class="text-text-muted block text-xs">Use Case</span>
              <span class="font-medium text-text-primary">${useCases.find(u => u.id === state.useCase)?.label || state.useCase}</span>
            </div>
            <div>
              <span class="text-text-muted block text-xs">Meeting Type</span>
              <span class="font-medium text-text-primary">${meetingTypes.find(m => m.id === state.meetingType)?.label || state.meetingType}</span>
            </div>
            <div>
              <span class="text-text-muted block text-xs">Maturity</span>
              <span class="font-medium text-text-primary">${state.maturity}</span>
            </div>
            <div>
              <span class="text-text-muted block text-xs">Persona</span>
              <span class="font-medium text-text-primary">${personas.find(p => p.id === state.persona)?.label || state.persona}</span>
            </div>
            <div>
              <span class="text-text-muted block text-xs">Competitors</span>
              <span class="font-medium text-text-primary">${state.competitors.map(c => competitors.find(x => x.id === c)?.label).join(', ')}</span>
            </div>
          </div>
        </div>

        <!-- Positioning Statement -->
        <div class="rounded-lg border border-sas-blue/30 bg-sas-blue/5 p-4">
          <h3 class="text-sm font-semibold text-sas-blue uppercase tracking-wide mb-2">Positioning Statement</h3>
          <p class="text-text-primary font-medium italic">"${positioning}"</p>
        </div>

        <!-- Recommended Battle Cards -->
        ${relevantCards.length > 0 ? `
        <div class="rounded-lg border border-border-default bg-bg-surface p-4">
          <h3 class="text-sm font-semibold text-text-secondary uppercase tracking-wide mb-3">Recommended Battle Cards</h3>
          <div class="space-y-2">
            ${relevantCards.map(card => `
              <a href="${base}/battlecards/${card.slug}/" class="flex items-center justify-between rounded-md border border-border-default p-3 hover:bg-bg-elevated transition-colors">
                <span class="font-medium text-text-primary">${card.name}</span>
                <span class="text-xs text-text-link">Open →</span>
              </a>
            `).join('')}
          </div>
        </div>
        ` : ''}

        <!-- Dynamic Scoping Questions -->
        <div class="rounded-lg border border-border-default bg-bg-surface p-4">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-semibold text-text-secondary uppercase tracking-wide">Scoping Questions</h3>
            <span class="text-[11px] text-text-muted">${matchLabel(matchType)}</span>
          </div>
          ${matchContext ? `<p class="text-xs text-text-muted italic mb-4 border-l-2 border-sas-blue/30 pl-3">${matchContext}</p>` : ''}
          <div class="space-y-4">
            ${matchedQuestions.map((q, idx) => `
              <div class="rounded-md border border-border-default p-3 space-y-2">
                <div class="flex items-start justify-between gap-2">
                  <span class="text-sm font-medium text-text-primary leading-snug"><span class="text-text-muted mr-1">${idx + 1}.</span> ${q.question}</span>
                </div>
                <div class="flex items-center gap-2 flex-wrap">
                  ${tierBadge(q.viyaTier)}
                  ${priorityLabel(q.priority)}
                  <span class="text-[10px] text-text-muted">→ ${q.mapsTo}</span>
                </div>
                <p class="text-xs text-text-muted leading-relaxed"><strong>Intent:</strong> ${q.intent}</p>
              </div>
            `).join('')}
          </div>
        </div>

        <!-- Meeting Tips -->
        <div class="rounded-lg border border-border-default bg-bg-surface p-4">
          <h3 class="text-sm font-semibold text-text-secondary uppercase tracking-wide mb-3">Meeting Tips</h3>
          <ul class="space-y-2">
            ${tips.map(t => `
              <li class="flex items-start gap-2 text-sm text-text-primary">
                <span class="text-sas-teal mt-0.5">•</span>
                <span>${t}</span>
              </li>
            `).join('')}
          </ul>
        </div>
      </div>
    `;

    // Event listeners for prep sheet actions
    document.getElementById('btn-print').addEventListener('click', () => window.print());
    document.getElementById('btn-restart').addEventListener('click', () => {
      state.step = 1;
      state.industry = '';
      state.competitors = [];
      state.useCase = '';
      state.meetingType = '';
      state.maturity = '';
      state.persona = '';
      renderStep();
    });
    document.getElementById('btn-copy').addEventListener('click', () => {
      const sheet = document.getElementById('prep-sheet');
      const text = sheet.innerText;
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('btn-copy');
        btn.textContent = '✓ Copied!';
        setTimeout(() => { btn.textContent = '📋 Copy All'; }, 2000);
      });
    });
  }

  // ============================================================
  // EVENT LISTENERS
  // ============================================================
  btnBack.addEventListener('click', () => {
    if (state.step > 1) {
      state.step--;
      renderStep();
    }
  });

  // ============================================================
  // INIT
  // ============================================================
  hydrateFromURL();
  renderStep();
})();
</script>
