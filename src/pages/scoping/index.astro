---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/global/Breadcrumb.astro';

const base = import.meta.env.BASE_URL;

const industries = [
  { slug: 'banking', name: 'Banking & Financial Services', icon: '🏦', priority: 'high', questions: 12 },
  { slug: 'insurance', name: 'Insurance', icon: '🛡️', priority: 'high', questions: 8 },
  { slug: 'telco', name: 'Telecommunications', icon: '📡', priority: 'high', questions: 8 },
  { slug: 'government', name: 'Government', icon: '🏛️', priority: 'high', questions: 8 },
  { slug: 'retail', name: 'Retail & CPG', icon: '🛒', priority: 'medium', questions: 7 },
  { slug: 'healthcare', name: 'Healthcare & Life Sciences', icon: '🧬', priority: 'medium', questions: 7 },
  { slug: 'universal', name: 'Universal (All Industries)', icon: '🌐', priority: 'high', questions: 10 },
];

const priorityColors: Record<string, string> = {
  high: 'bg-danger/10 text-danger border-danger/30',
  medium: 'bg-warning/10 text-warning border-warning/30',
  low: 'bg-success/10 text-success border-success/30',
};
---

<BaseLayout title="Scoping Questions">
  <div class="mx-auto max-w-7xl px-4 py-8 space-y-8">
    <Breadcrumb items={[{ label: 'Scoping Questions' }]} />

    <!-- Header -->
    <div class="space-y-2">
      <h1 class="text-2xl font-bold text-text-primary">Scoping Questions</h1>
      <p class="text-text-secondary max-w-2xl">
        Industry-specific discovery questions designed to uncover pain points, qualify opportunities, and position SAS solutions effectively in the Philippine market.
      </p>
    </div>

    <!-- Three-Path Entry -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <a href={`${base}/wizard/`} class="group rounded-lg border border-border-default bg-bg-surface p-5 hover:border-sas-blue/50 hover:bg-bg-elevated transition-all">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-2xl">🧙</span>
          <h3 class="font-semibold text-text-primary group-hover:text-sas-blue transition-colors">Guided Flow</h3>
        </div>
        <p class="text-sm text-text-muted">Use the Meeting Prep Wizard to get tailored questions based on your specific meeting context.</p>
      </a>

      <div class="rounded-lg border-2 border-sas-blue/50 bg-bg-surface p-5">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-2xl">🏢</span>
          <h3 class="font-semibold text-sas-blue">By Industry</h3>
        </div>
        <p class="text-sm text-text-muted">Browse questions organized by industry vertical. Best for focused preparation.</p>
      </div>

      <a href="#universal" class="group rounded-lg border border-border-default bg-bg-surface p-5 hover:border-sas-blue/50 hover:bg-bg-elevated transition-all">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-2xl">🌐</span>
          <h3 class="font-semibold text-text-primary group-hover:text-sas-blue transition-colors">Universal</h3>
        </div>
        <p class="text-sm text-text-muted">Industry-agnostic questions that work in any discovery meeting.</p>
      </a>
    </div>

    <!-- Industry Grid -->
    <section>
      <h2 class="text-lg font-semibold text-text-primary mb-4">Select Industry</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {industries.map((industry) => (
          <a
            href={`${base}/scoping/${industry.slug}/`}
            id={industry.slug}
            class="group rounded-lg border border-border-default bg-bg-surface p-5 hover:border-sas-blue/50 hover:bg-bg-elevated transition-all"
          >
            <div class="flex items-start justify-between mb-3">
              <span class="text-3xl">{industry.icon}</span>
              <span class={`text-xs font-medium px-2 py-0.5 rounded-full border ${priorityColors[industry.priority]}`}>
                {industry.priority}
              </span>
            </div>
            <h3 class="font-semibold text-text-primary group-hover:text-sas-blue transition-colors mb-1">
              {industry.name}
            </h3>
            <p class="text-sm text-text-muted">
              {industry.questions} questions
            </p>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
