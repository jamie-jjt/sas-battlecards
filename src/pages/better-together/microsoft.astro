---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/global/Breadcrumb.astro';
import CollapsibleSection from '@components/battlecard/CollapsibleSection.astro';
import CopyButton from '@components/ui/CopyButton.astro';

const base = import.meta.env.BASE_URL;

const positioningStatement = "Microsoft provides the enterprise ecosystem — Azure infrastructure, Fabric for data integration, Power BI for reporting, and Copilot for productivity. SAS Viya on AKS delivers the advanced analytics, model governance, and industry solutions that Azure ML and Fabric's built-in analytics cannot match. For PH banks and insurers, this means leveraging their existing Microsoft investment while adding the regulatory-grade AI governance that BSP and IC require.";
---

<BaseLayout title="Better Together — Microsoft">
  <div class="mx-auto max-w-7xl px-4 py-8 space-y-6">
    <Breadcrumb items={[
      { label: 'Better Together', href: `${base}/better-together/` },
      { label: 'Microsoft' },
    ]} />

    <div class="flex items-center gap-3">
      <span class="text-3xl">🪟</span>
      <h1 class="text-2xl font-bold text-text-primary">SAS + Microsoft</h1>
    </div>

    <CollapsibleSection title="Integration Story" icon="📖" defaultOpen={true}>
      <p class="text-sm text-text-secondary leading-relaxed">
        SAS and Microsoft have a deep strategic partnership. SAS Viya runs on Azure Kubernetes Service (AKS) with native integration to Azure Synapse, Fabric, and Power BI. The key positioning: Microsoft handles the productivity layer (Office 365, Teams, Power BI for consumption-tier reporting) while SAS handles the advanced analytics layer (complex modeling, production ML, real-time decisioning, regulatory compliance).
      </p>
      <p class="text-sm text-text-secondary leading-relaxed mt-3">
        In the Philippine market, most enterprises are Microsoft shops. SAS isn't asking them to leave Microsoft — SAS runs ON Microsoft. The differentiation is in what runs on top: SAS provides purpose-built fraud, AML, risk, and forecasting solutions that Azure ML/Fabric ML don't offer, with the governance and audit trails that Philippine regulators expect.
      </p>
    </CollapsibleSection>

    <CollapsibleSection title="Architecture" icon="🏗️" defaultOpen={true}>
      <pre class="text-xs font-mono text-text-secondary bg-bg-base rounded-lg p-4 overflow-x-auto border border-border-default">
┌─────────────────────────────────────────────────────────┐
│                MICROSOFT AZURE (Southeast Asia)          │
├─────────────────────────────────────────────────────────┤
│                                                         │
│  ┌──────────────┐    ┌──────────────────────────────┐  │
│  │ Azure Data   │◄──►│     SAS VIYA on AKS          │  │
│  │ Lake / Fabric│    │                              │  │
│  └──────────────┘    │  ┌─────────┐ ┌───────────┐   │  │
│                      │  │Model    │ │Fraud      │   │  │
│  ┌──────────────┐    │  │Manager  │ │Management │   │  │
│  │ Azure SQL /  │◄──►│  └─────────┘ └───────────┘   │  │
│  │ Synapse      │    │                              │  │
│  └──────────────┘    │  ┌─────────┐ ┌───────────┐   │  │
│                      │  │Visual   │ │Intelligent│   │  │
│  ┌──────────────┐    │  │Analytics│ │Decisioning│   │  │
│  │ Power BI     │◄───│  └─────────┘ └───────────┘   │  │
│  │ (Reporting)  │    │                              │  │
│  └──────────────┘    └──────────────────────────────┘  │
│                                                         │
│  ┌──────────────┐    ┌──────────────────────────────┐  │
│  │ Azure ML     │    │  Complementary — not          │  │
│  │ (Coexist)   │    │  competitive when SAS adds    │  │
│  └──────────────┘    │  governance + industry soln   │  │
│                      └──────────────────────────────┘  │
│  ┌──────────────┐                                      │
│  │ Entra ID     │── SSO/Auth for SAS Viya             │
│  └──────────────┘                                      │
└─────────────────────────────────────────────────────────┘</pre>
    </CollapsibleSection>

    <CollapsibleSection title="Partner When" icon="✅" defaultOpen={true}>
      <ul class="space-y-2">
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-success shrink-0 mt-0.5">✓</span>
          <span>Customer is Microsoft-standardized (EA agreement, Azure-first)</span>
        </li>
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-success shrink-0 mt-0.5">✓</span>
          <span>Power BI is for reporting; SAS is for advanced analytics and decisioning</span>
        </li>
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-success shrink-0 mt-0.5">✓</span>
          <span>Regulated industry needing BSP/IC/AMLC compliance features</span>
        </li>
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-success shrink-0 mt-0.5">✓</span>
          <span>Microsoft account team is supporting/endorsing SAS deployment</span>
        </li>
      </ul>
    </CollapsibleSection>

    <CollapsibleSection title="Compete When" icon="⚔️" defaultOpen={true}>
      <ul class="space-y-2">
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-danger shrink-0 mt-0.5">✗</span>
          <span>Microsoft is positioning Fabric ML + Azure ML as 'complete' replacement</span>
        </li>
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-danger shrink-0 mt-0.5">✗</span>
          <span>Customer says 'Power BI does everything we need for analytics'</span>
        </li>
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-danger shrink-0 mt-0.5">✗</span>
          <span>Budget locked into Microsoft ELA with no room for additional platform spend</span>
        </li>
      </ul>
    </CollapsibleSection>

    <CollapsibleSection title="Positioning Statement" icon="💬" defaultOpen={true}>
      <div class="flex items-start gap-3">
        <p class="text-sm text-text-secondary leading-relaxed flex-1">{positioningStatement}</p>
        <CopyButton text={positioningStatement} label="Copy" />
      </div>
    </CollapsibleSection>
  </div>
</BaseLayout>
