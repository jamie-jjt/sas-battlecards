    <CollapsibleSection title="Partner When" icon="вң…" defaultOpen={true}>
      <ul class="space-y-2">
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-success shrink-0 mt-0.5">вң“</span>
          <span>Customer is AWS-standardized (all workloads on AWS)</span>
        </li>
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-success shrink-0 mt-0.5">вң“</span>
          <span>Need SAS-specific solutions (fraud, AML, risk, clinical) that SageMaker can't deliver</span>
        </li>
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-success shrink-0 mt-0.5">вң“</span>
          <span>AWS Marketplace procurement simplifies purchasing for customer</span>
        </li>
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-success shrink-0 mt-0.5">вң“</span>
          <span>Customer needs business-user analytics (not just data scientist tooling)</span>
        </li>
      </ul>
    </CollapsibleSection>

    <CollapsibleSection title="Compete When" icon="вҡ”пёҸ" defaultOpen={true}>
      <ul class="space-y-2">
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-danger shrink-0 mt-0.5">вң—</span>
          <span>AWS is positioning SageMaker as a 'complete ML platform' replacement for SAS</span>
        </li>
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-danger shrink-0 mt-0.5">вң—</span>
          <span>Customer evaluating cloud ML for the first time (no existing SAS footprint)</span>
        </li>
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="text-danger shrink-0 mt-0.5">вң—</span>
          <span>Budget is limited to AWS committed spend only</span>
        </li>
      </ul>
    </CollapsibleSection>

