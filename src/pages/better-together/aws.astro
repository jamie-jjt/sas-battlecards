---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/global/Breadcrumb.astro';
import CollapsibleSection from '@components/battlecard/CollapsibleSection.astro';
import CopyButton from '@components/ui/CopyButton.astro';

const base = import.meta.env.BASE_URL;

const positioningStatement = "AWS provides the cloud infrastructure foundation вҖ” compute, storage, networking, and managed services. SAS Viya runs natively on Amazon EKS, leveraging AWS infrastructure while adding purpose-built analytics, AI governance, and industry-specific solutions that AWS's native ML services (SageMaker) don't provide. For PH customers, this means on-demand scalability with SAS's proven regulatory compliance.";
---

<BaseLayout title="Better Together вҖ” AWS">
  <div class="mx-auto max-w-7xl px-4 py-8 space-y-6">
    <Breadcrumb items={[
      { label: 'Better Together', href: `${base}/better-together/` },
      { label: 'AWS' },
    ]} />

    <div class="flex items-center gap-3">
      <span class="text-3xl">вҳҒпёҸ</span>
      <h1 class="text-2xl font-bold text-text-primary">SAS + AWS</h1>
    </div>

    <CollapsibleSection title="Integration Story" icon="рҹ“–" defaultOpen={true}>
      <p class="text-sm text-text-secondary leading-relaxed">
        SAS Viya deploys natively on Amazon EKS (Elastic Kubernetes Service), consuming AWS infrastructure services вҖ” S3 for object storage, RDS for metadata, CloudWatch for monitoring. The SAS/AWS partnership is mature with a dedicated joint engineering team ensuring first-class integration. SAS is available on AWS Marketplace for simplified procurement.
      </p>
      <p class="text-sm text-text-secondary leading-relaxed mt-3">
        For Philippine enterprises, AWS provides the scalable infrastructure while SAS adds the governed analytics layer, industry solutions (fraud, AML, risk), and business-user interfaces that SageMaker doesn't offer. Data stays in the AWS Singapore or upcoming Manila region for sovereignty requirements.
      </p>
    </CollapsibleSection>

    <CollapsibleSection title="Architecture" icon="рҹҸ—пёҸ" defaultOpen={true}>
