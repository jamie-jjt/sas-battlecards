---
import Header from '@components/global/Header.astro';
import MobileNav from '@components/global/MobileNav.astro';
import Footer from '@components/global/Footer.astro';
import SkipLink from '@components/global/SkipLink.astro';
import SearchModal from '@components/search/SearchModal.astro';
import '@styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Philippine SAS SE Competitive Intelligence Tool' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d1117" />
    <meta name="color-scheme" content="dark light" />

    <!-- Preload critical fonts -->
    <link rel="preload" href="/sas-battlecards/fonts/inter-variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- PWA -->
    <link rel="manifest" href="/sas-battlecards/manifest.json" />
    <link rel="icon" type="image/svg+xml" href="/sas-battlecards/favicon.svg" />

    <title>{title} | SAS Battle Cards</title>
  </head>

  <body class="bg-bg-base text-text-primary">
    <SkipLink />
    <Header currentPath={currentPath} />

    <!-- Main content area with top padding for fixed header and bottom for mobile nav -->
    <main id="main-content" class="flex-1 pt-14 pb-16 md:pb-0" tabindex="-1">
      <slot />
    </main>

    <Footer />
    <MobileNav currentPath={currentPath} />
    <SearchModal />

    <!-- Service Worker Registration -->
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sas-battlecards/sw.js').catch(() => {
            // SW registration failed — offline won't work but app still functions
          });
        });
      }
    </script>
  </body>
</html>
